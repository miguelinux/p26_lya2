digraph Automata {
    fontname="Helvetica,Arial,sans-serif"
    node [fontname="Helvetica,Arial,sans-serif"]
    edge [fontname="Helvetica,Arial,sans-serif"]
    rankdir=LR;

    node [shape=doublecircle]; 1 2 4 7 8 9 10 12 15 ;
    node [shape=circle];

    
    0 -> 1 [label="[+ -]"];
    0 -> 10 [label="[* % = ; , ( ) { } < >]"];
    0 -> 2 [label="[0-9]"];
    0 -> 8 [label="[a-zA-Z_]"];
    0 -> 9 [label="#"];
    0 -> 11 [label="\""];
    0 -> 13 [label="/"];
    0 -> 3 [label="."];


    
    1 -> 2 [label="[0-9]"]; 
    2 -> 2 [label="[0-9]"];
    2 -> 3 [label="."];    
    2 -> 5 [label="[eE]"];

    3 -> 4 [label="[0-9]"]; 
    4 -> 4 [label="[0-9]"];
    4 -> 5 [label="[eE]"];

    5 -> 6 [label="[+-]"];
    5 -> 7 [label="[0-9]"];
    6 -> 7 [label="[0-9]"];
    7 -> 7 [label="[0-9]"];


    8 -> 8 [label="[a-zA-Z0-9_]"];
    9 -> 9 [label="include"];

    
    11 -> 11 [label="[a-zA-Z0-9]"];
    11 -> 12 [label="\""];
     

    13 -> 14 [label="/"];        
    14 -> 14 [label="[a-zA-Z0-9]"];

    14 -> 15 [label="Enter"];   


    }
