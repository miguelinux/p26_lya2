digraph analizador_lexico {
	fontname="Helvetica,Arial,sans-serif"
	node [fontname="Helvetica,Arial,sans-serif"]
	edge [fontname="Helvetica,Arial,sans-serif"]
	rankdir=LR;

	// Estados de aceptación
	node [shape = doublecircle]; 
	2;   // ENTERO
	4;   // FLOTANTE
	7;   // NOTACION CIENTIFICA
	8;   // IDENTIFICADOR
	20;  // PALABRAS RESERVADAS
	10;  // +
	11;  // -
	13;  // =
	12;  // ++ -- ==
	17;  // *
	18;  // /
	19;  // %
	14;  // DELIMITADORES
	16;  // #include
	22;  // COMENTARIO

	node [shape = circle];

	// =========================
	// NÚMEROS
	// =========================

	0 -> 1 [label = "[0-9]"];
	1 -> 2 [label = "[0-9]"];
	2 -> 2 [label = "[0-9]"];
	2 -> 3 [label = "."];
	2 -> 5 [label = "e,E"];

	3 -> 4 [label = "[0-9]"];
	4 -> 4 [label = "[0-9]"];
	4 -> 5 [label = "e,E"];

	// flotantes que empiezan con punto (.3)
	0 -> 23 [label = "."];
	23 -> 4 [label = "[0-9]"];

	// notación científica
	5 -> 6 [label = "+,-"];
	5 -> 7 [label = "[0-9]"];
	6 -> 7 [label = "[0-9]"];
	7 -> 7 [label = "[0-9]"];

	// =========================
	// IDENTIFICADORES
	// =========================

	0 -> 8 [label = "[A-Za-z,_]"];
	8 -> 8 [label = "[A-Za-z,0-9,_]"];

	// =========================
	// PALABRAS RESERVADAS
	// =========================

	8 -> 20 [label = "if else while for int float double char return void switch case break continue do"];

	// =========================
	// OPERADORES
	// =========================

	0 -> 10 [label = "+"];
	0 -> 11 [label = "-"];
	0 -> 13 [label = "="];
	0 -> 17 [label = "*"];
	0 -> 18 [label = "/"];
	0 -> 19 [label = "%"];

	// operadores dobles permitidos

	10 -> 12 [label = "+"];   // ++
	11 -> 12 [label = "-"];   // --
	13 -> 12 [label = "="];   // ==

	// =========================
	// DELIMITADORES
	// =========================

	0 -> 14 [label = "; , ( ) { } [ ]"];

	// =========================
	// DIRECTIVA #include
	// =========================

	0 -> 15 [label = "#"];
	15 -> 16 [label = "include"];

	// =========================
	// COMENTARIOS //
	// =========================

	18 -> 21 [label = "/"];
	21 -> 22 [label = "cualquier caracter"];
	22 -> 22 [label = "cualquier caracter"];

}