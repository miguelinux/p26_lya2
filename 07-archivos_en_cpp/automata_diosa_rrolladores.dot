digraph Automata {
    rankdir=LR;
    node [fontname="Helvetica"];
    edge [fontname="Helvetica"];

    
    node [shape = doublecircle]; q0 q1 q2 q5 q6 q7;
    
  
    node [shape = circle]; q3 q4;

    // Flecha de estado inicial
    inicio [shape=none, label=""];
    inicio -> q0;

 
    q1 [xlabel="identificadores"];
    q2 [xlabel="entero>"];
    q7 [xlabel=""];

   
    q0 -> q1 [label="a-zA-Z_"];
    q1 -> q1 [label="a-zA-Z_"];

   
    q0 -> q2 [label="0-9"];
    q0 -> q3 [label="+, -"];
    q3 -> q2 [label="0-9"];
    q2 -> q2 [label="0-9"];

  
    q0 -> q4 [label="."];
    q4 -> q5 [label="0-9"];
    q2 -> q5 [label="."];
    q5 -> q5 [label="0-9"];

  
    q2 -> q6 [label="e/E"];
    q5 -> q6 [label="e/E, +, -"];
    q6 -> q6 [label="0-9"];

    
    q0 -> q7 [label="(  )  {  }  [  ]  ;  ,  :"];
}
